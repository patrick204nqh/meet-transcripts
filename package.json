{
  "name": "meet-transcripts",
  "version": "1.0.0",
  "description": "E2E tests for the meet-transcripts Chrome extension",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "pretest": "vite build --mode test",
    "test": "playwright test --project=e2e",
    "test:screenshots": "playwright test --project=screenshots",
    "test:smoke": "HEADED=1 playwright test --project=e2e",
    "test:ui": "playwright test --ui",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/chrome": "^0.1.40",
    "@vitest/coverage-v8": "^4.1.5",
    "happy-dom": "^20.9.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
