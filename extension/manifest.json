{
  "manifest_version": 3,
  "name": "meet-transcripts",
  "version": "1.0.0",
  "description": "meet-transcripts — Google Meet transcript capture.",
  "action": {
    "default_icon": "icon.png",
    "default_popup": "popup.html"
  },
  "icons": {
    "128": "icon.png"
  },
  "permissions": [
    "storage",
    "downloads",
    "scripting"
  ],
  "host_permissions": [
    "https://meet.google.com/*"
  ],
  "optional_permissions": [
    "notifications"
  ],
  "background": {
    "service_worker": "background.js"
  }
}